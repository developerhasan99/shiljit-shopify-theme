{% schema %}
{
  "name": "Performance Support",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "PERFORMANCE SUPPORT"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "When erections feel weaker, it's usually not \"just age.\""
    },
    {
      "type": "textarea",
      "id": "main_subheading",
      "label": "Main Subheading",
      "default": "Many men notice changes from stress, circulation, and low daily energy. Xara supports the foundations of sexual performance — consistently."
    },
    {
      "type": "header",
      "content": "Right Card Settings"
    },
    {
      "type": "text",
      "id": "right_card_badge",
      "label": "Right Card Badge",
      "default": "HOW IT CONNECTS TO PERFORMANCE"
    },
    {
      "type": "text",
      "id": "right_card_heading",
      "label": "Right Card Heading",
      "default": "Erections are a blood-flow + energy issue."
    },
    {
      "type": "textarea",
      "id": "right_card_description",
      "label": "Right Card Description",
      "default": "When circulation is sluggish and daily energy is low, performance often drops first. Xara is designed to support the foundations: circulation support, stress response, and stamina.*"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View Lab Report"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "footer_info",
      "label": "Footer Info",
      "default": "Third-party tested • Fulvic acid verified • Heavy metals screened"
    },
    {
      "type": "textarea",
      "id": "fda_disclaimer",
      "label": "FDA Disclaimer",
      "default": "*These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure, or prevent any disease."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Left Column Feature",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "highlight",
      "name": "Right Card Highlight",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Performance Support",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Circulation Support",
            "description": "May help support blood flow and performance when it matters."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Drive & Sexual Wellness",
            "description": "May help support libido, confidence, and intimacy."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Stamina & Recovery",
            "description": "May help support endurance and healthy energy metabolism."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Supports circulation*",
            "description": "May help support blood flow and firmness."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Supports drive & confidence*",
            "description": "May help support libido and sexual wellness."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Supports stamina*",
            "description": "May help support endurance and recovery."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<section
  class="py-16 md:py-24"
  style="background: radial-gradient(900px 520px at 18% 12%, rgba(230, 198, 155, .10), transparent 60%), linear-gradient(180deg, #070708, #0a0a0b 60%, #070708);"
>
  <div class="max-w-[1300px] mx-auto px-6">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
      <!-- Left Column -->
      <div class="lg:w-7/12 flex flex-col justify-center text-left">
        <span class="inline-block border border-[#2a2620] bg-[#121212]/50 rounded-full px-5 py-2 text-[10px] md:text-xs uppercase tracking-[0.2em] text-[#e5e5e5] font-semibold w-fit mb-8">
          {{ section.settings.badge_text }}
        </span>

        <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-[1.1] mb-8 tracking-tight">
          {{ section.settings.main_heading }}
        </h2>

        <p class="text-[#b1b1b1] text-md md:text-lg font-medium leading-relaxed max-w-xl mb-12">
          {{ section.settings.main_subheading }}
        </p>

        <div class="space-y-4">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <div class="p-6 md:p-8 rounded-[1.5rem] bg-[#0c0c0d]/50 border border-[#1a1a1b] hover:border-[#2a2620] transition-colors group">
                <h4 class="text-white text-lg font-bold mb-2 group-hover:text-[#E6C69B] transition-colors">
                  {{ block.settings.title }}
                </h4>
                <p class="text-[#8e8e8e] text-sm md:text-base font-medium">{{ block.settings.description }}</p>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <p class="mt-12 text-[#4a4a4a] text-[10px] md:text-xs font-medium leading-relaxed max-w-2xl italic">
          {{ section.settings.fda_disclaimer }}
        </p>
      </div>

      <!-- Right Column -->
      <div class="lg:w-5/12">
        <div class="batch rounded-[2.5rem] bg-[#0c0c0d] border border-[#1a1a1b] p-8 md:p-12 shadow-2xl relative h-full flex flex-col">
          <span class="block text-[#8e8e8e] text-[10px] uppercase tracking-[0.2em] font-bold mb-6">
            {{ section.settings.right_card_badge }}
          </span>

          <h3 class="text-white text-2xl md:text-3xl font-bold mb-6 leading-tight">
            {{ section.settings.right_card_heading }}
          </h3>

          <p class="text-[#8e8e8e] text-sm md:text-base font-medium leading-relaxed mb-8">
            {{ section.settings.right_card_description }}
          </p>

          <div class="space-y-4 mb-10 flex-grow">
            {%- for block in section.blocks -%}
              {%- if block.type == 'highlight' -%}
                <div class="p-5 rounded-2xl bg-[#121212] border border-[#1a1a1b] flex flex-col gap-1">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-[#E6C69B]"></div>
                    <h5 class="text-white text-sm md:text-base font-bold">{{ block.settings.title }}</h5>
                  </div>
                  <p class="text-[#8e8e8e] text-xs md:text-sm pl-5 font-medium leading-normal">
                    {{ block.settings.description }}
                  </p>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>

          <div class="mt-auto space-y-6">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="w-full inline-block bg-[#E6C69B] text-black text-center py-5 rounded-full font-bold text-base hover:opacity-90 transition-opacity whitespace-nowrap shadow-[0_0_20px_rgba(230,198,155,0.2)]"
            >
              {{ section.settings.button_text }}
            </a>

            <p class="text-[#4a4a4a] text-[10px] font-bold tracking-wider uppercase text-center">
              {{ section.settings.footer_info }}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
