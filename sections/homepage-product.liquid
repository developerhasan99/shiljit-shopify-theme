{% schema %}
{
  "name": "Homepage Product",
  "settings": [
    {
      "type": "header",
      "content": "Tab 1"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 Label",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "tab_1_collection",
      "label": "Tab 1 Collection"
    },
    {
      "type": "header",
      "content": "Tab 2"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 Label",
      "default": "New Arrivals"
    },
    {
      "type": "collection",
      "id": "tab_2_collection",
      "label": "Tab 2 Collection"
    },
    {
      "type": "header",
      "content": "Tab 3"
    },
    {
      "type": "text",
      "id": "tab_3_label",
      "label": "Tab 3 Label",
      "default": "Bundles"
    },
    {
      "type": "collection",
      "id": "tab_3_collection",
      "label": "Tab 3 Collection"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Homepage Product"
    }
  ]
}
{% endschema %}

<section class="py-12 md:py-20" id="homepage-product-{{ section.id }}">
  <div class="max-w-[1300px] mx-auto px-6">
    <!-- Tabs Navigation -->
    <div class="flex justify-center gap-8 md:gap-12 mb-10 md:mb-16 border-b border-gray-100">
      {% for i in (1..3) %}
        {% capture label_id %}tab_{{ i }}_label{% endcapture %}
        {% if section.settings[label_id] != blank %}
          <button
            class="tab-trigger pb-4 text-base md:text-lg font-bold tracking-wide transition-all duration-300 relative {% if i == 1 %}active text-black{% else %}text-[#d3bc8d] opacity-60 hover:opacity-100{% endif %}"
            data-tab="grid-{{ i }}-{{ section.id }}"
          >
            {{ section.settings[label_id] }}
            <span
              class="absolute bottom-0 left-0 w-full h-[2px] bg-black scale-x-0 transition-transform duration-300 {% if i == 1 %}scale-x-100{% endif %}"
            ></span>
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Product Grids -->
    <div class="relative">
      {% for i in (1..3) %}
        {% capture collection_id %}tab_{{ i }}_collection{% endcapture %}
        {% assign collection = section.settings[collection_id] %}

        <div
          id="grid-{{ i }}-{{ section.id }}"
          class="tab-content grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 {% if i == 1 %}block{% else %}hidden{% endif %}"
        >
          {% if collection != blank and collection.products.size > 0 %}
            {% for product in collection.products limit: 4 %}
              <a href="{{ product.url }}" class="product-card group cursor-pointer flex flex-col h-full">
                <!-- Image Container -->
                <div class="relative aspect-square mb-4 overflow-hidden bg-[#f3f3f3]">
                  {% if product.featured_media %}
                    {{
                      product.featured_media
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
                        widths: '400, 600, 800'
                    }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                  {% endif %}

                  <!-- Top Badges (Example for card 1) -->
                  {% if forloop.first and i == 1 %}
                    <div class="absolute top-3 left-3 bg-black text-white text-[10px] font-bold px-3 py-1 rounded-sm uppercase tracking-tighter">
                      Best Seller
                    </div>
                  {% endif %}

                  <!-- Bottom Info (Example for card 4) -->
                  {% if forloop.index == 4 %}
                    <div class="absolute top-3 right-3 bg-[#3a523a] text-white text-[10px] font-bold px-3 py-1 rounded-sm uppercase tracking-tighter">
                      Upgraded Formula
                    </div>
                  {% endif %}
                </div>

                <!-- Product Info -->
                <div class="flex flex-col flex-grow text-left">
                  <h3 class="text-sm md:text-base font-bold text-black mb-1 leading-snug">
                    {{ product.title }}
                  </h3>
                  <div class="text-sm md:text-base font-medium text-[#444444]">
                    {{ product.price_min | money_without_trailing_zeros }} USD
                    {% if product.price_varies %}
                      – {{ product.price_max | money_without_trailing_zeros }} USD
                    {% endif %}
                  </div>
                </div>

                <!-- Footer Logos (Example for card 4 or specific collection) -->
                {% if forloop.index == 4 %}
                  <div class="mt-3 pt-3 border-t border-gray-100 flex items-center justify-between opacity-80 grayscale active:grayscale-0">
                    <span class="text-[8px] font-extrabold uppercase text-[#666]">As seen in...</span>
                    <div class="flex gap-2">
                      <!-- Small SVG placeholders for logos -->
                      <div class="w-8 h-4 bg-gray-200 rounded-sm"></div>
                      <div class="w-8 h-4 bg-gray-300 rounded-sm"></div>
                      <div class="w-8 h-4 bg-gray-200 rounded-sm"></div>
                    </div>
                  </div>
                {% endif %}
              </a>
            {% endfor %}
          {% else %}
            <!-- Placeholders -->
            {% for j in (1..4) %}
              <div class="product-card flex flex-col opacity-50">
                <div class="aspect-square bg-gray-100 mb-4 rounded-sm"></div>
                <div class="h-4 bg-gray-100 w-3/4 mb-2"></div>
                <div class="h-4 bg-gray-100 w-1/2"></div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- Shop Now Button -->
    <div class="mt-12 md:mt-16 flex justify-center">
      <a
        href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
        class="inline-block bg-black text-white text-sm font-bold px-12 py-4 uppercase tracking-[0.2em] hover:bg-black/90 transition-colors shadow-lg"
      >
        {{ section.settings.button_text }}
      </a>
    </div>
  </div>
</section>

<style>
  .tab-trigger.active span {
    transform: scaleX(1);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sectionId = 'homepage-product-{{ section.id }}';
    const section = document.getElementById(sectionId);
    if (!section) return;

    const tabs = section.querySelectorAll('.tab-trigger');
    const contents = section.querySelectorAll('.tab-content');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.getAttribute('data-tab');

        // Update Tabs UI
        tabs.forEach((t) => {
          t.classList.remove('active', 'text-black');
          t.classList.add('text-[#d3bc8d]', 'opacity-60');
        });
        tab.classList.add('active', 'text-black');
        tab.classList.remove('text-[#d3bc8d]', 'opacity-60');

        // Switch Grid
        contents.forEach((content) => {
          if (content.id === targetId) {
            content.classList.remove('hidden');
            content.classList.add('block');
          } else {
            content.classList.remove('block');
            content.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
