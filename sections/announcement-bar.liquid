<div class="announcement-bar-container sticky top-0 left-0 right-0 z-50 bg-black text-white py-4 border-b border-white/10">
  <div class="max-w-[1300px] mx-auto px-6 flex flex-col md:flex-row justify-center items-center gap-8">
    <!-- Left: Promo Text -->
    <div class="text-center md:text-left">
      <p class="text-sm m-0 md:text-base font-bold uppercase tracking-tight leading-tight">
        Up to 70% OFF + Free gifts.
      </p>
      <p class="text-[10px] m-0 md:text-xs text-[#b1b1b1] font-medium">Today only. No Code required.</p>
    </div>

    <!-- Right: Countdown Timer -->
    <div id="countdown-timer" class="flex items-center gap-2 text-center">
      <div class="flex flex-col items-center">
        <span class="days text-xl md:text-2xl font-black text-red-600 leading-none">00</span>
        <span class="text-[8px] md:text-[10px] uppercase font-bold text-[#8e8e8e] mt-1">Days</span>
      </div>
      <span class="text-xl md:text-2xl font-black text-red-600 self-start mt-[-2px]">:</span>
      <div class="flex flex-col items-center">
        <span class="hours text-xl md:text-2xl font-black text-red-600 leading-none">02</span>
        <span class="text-[8px] md:text-[10px] uppercase font-bold text-[#8e8e8e] mt-1">Hrs</span>
      </div>
      <span class="text-xl md:text-2xl font-black text-red-600 self-start mt-[-2px]">:</span>
      <div class="flex flex-col items-center">
        <span class="minutes text-xl md:text-2xl font-black text-red-600 leading-none">23</span>
        <span class="text-[8px] md:text-[10px] uppercase font-bold text-[#8e8e8e] mt-1">Mins</span>
      </div>
      <span class="text-xl md:text-2xl font-black text-red-600 self-start mt-[-2px]">:</span>
      <div class="flex flex-col items-center">
        <span class="seconds text-xl md:text-2xl font-black text-red-600 leading-none">35</span>
        <span class="text-[8px] md:text-[10px] uppercase font-bold text-[#8e8e8e] mt-1">Secs</span>
      </div>
    </div>
  </div>
</div>

<script>
  function startCountdown() {
    // Set target date (e.g., end of today)
    const now = new Date();
    const targetDate = new Date(now.getFullYear(), now.getMonth(), now.getDate() + 1);

    function updateTimer() {
      const currentTime = new Date().getTime();
      const distance = targetDate - currentTime;

      const d = Math.floor(distance / (1000 * 60 * 60 * 24));
      const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const s = Math.floor((distance % (1000 * 60)) / 1000);

      document.querySelector('.days').innerText = d.toString().padStart(2, '0');
      document.querySelector('.hours').innerText = h.toString().padStart(2, '0');
      document.querySelector('.minutes').innerText = m.toString().padStart(2, '0');
      document.querySelector('.seconds').innerText = s.toString().padStart(2, '0');

      if (distance < 0) {
        clearInterval(timerInterval);
        document.getElementById('countdown-timer').innerHTML = 'EXPIRED';
      }
    }

    const timerInterval = setInterval(updateTimer, 1000);
    updateTimer();
  }
  startCountdown();
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
