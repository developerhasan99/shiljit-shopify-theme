{% endschema %}

<section class="relative bg-[#f3f3f3] pb-24 pt-40 overflow-hidden">
  <!-- Large Quote Icon (Background) -->

  <div class="absolute  inset-[40px] flex justify-center items-start pointer-events-none">
    <div class="mt-6 opacity-10 w-28">
      <svg viewBox="0 0 123 85" fill="black">
        <path d="M53.704 32.96c0 9.02-1.386 16.768-4.157 23.244-2.772 6.708-6.353 12.143-10.741 16.306-4.39 4.395-9.355 7.517-14.899 9.367C18.132 83.96 12.473 85 6.93 85V72.857c6.005 0 11.664-2.082 16.977-6.245 5.082-3.932 8.084-9.367 9.009-16.306-.694.231-1.502.463-2.426.694a33.25 33.25 0 0 1-2.425.694c-1.155.231-2.426.347-3.812.347-6.93 0-12.704-2.66-17.323-7.98C2.31 38.973 0 32.96 0 26.021c0-6.94 2.425-13.069 7.276-18.388C11.896 2.544 18.132 0 25.986 0c8.777 0 15.591 3.238 20.442 9.714 4.85 6.708 7.276 14.456 7.276 23.245Zm69.296 0c0 9.02-1.386 16.768-4.158 23.244-2.772 6.708-6.352 12.143-10.741 16.306-4.388 4.395-9.355 7.517-14.898 9.367C87.428 83.96 81.769 85 76.225 85V72.857c6.006 0 11.665-2.082 16.978-6.245 5.081-3.932 8.084-9.367 9.008-16.306-.693.231-1.501.463-2.425.694a33.25 33.25 0 0 1-2.425.694c-1.155.231-2.426.347-3.812.347-6.93 0-12.704-2.66-17.324-7.98-4.62-5.088-6.93-11.102-6.93-18.04 0-6.94 2.426-13.069 7.277-18.388C81.192 2.544 87.428 0 95.282 0c8.777 0 15.591 3.238 20.442 9.714C120.575 16.422 123 24.17 123 32.96Z"/>
      </svg>
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto overflow-hidden">
    <div id="carousel" class="flex transition-transform duration-500 ease-in-out">
      <!-- Slide 1 -->
      <div class="min-w-full text-center px-6">
        <p class="text-3xl font-medium leading-snug mb-10">
          Love the product energizes me feel good after the exercise. Delivery time has been excellent.
        </p>

        <div class="flex justify-center mb-4 text-black text-2xl">★★★★★</div>

        <div class="flex justify-center items-center gap-2 font-medium">
          David L.
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="black" stroke-width="2">
            <path d="M9 12L11 14L15 10"/>
            <circle cx="12" cy="12" r="9"/>
          </svg>
        </div>
      </div>

      <!-- Slide 2 -->
      <div class="min-w-full text-center px-6">
        <p class="text-3xl font-medium leading-snug mb-10">Absolutely amazing quality and super fast shipping.</p>
        <div class="flex justify-center mb-4 text-black text-2xl">★★★★★</div>
        <div class="flex justify-center items-center gap-2 font-medium">Sarah M.</div>
      </div>

      <!-- Slide 3 -->
      <div class="min-w-full text-center px-6">
        <p class="text-3xl font-medium leading-snug mb-10">Best purchase this year. Highly recommended.</p>
        <div class="flex justify-center mb-4 text-black text-2xl">★★★★★</div>
        <div class="flex justify-center items-center gap-2 font-medium">John D.</div>
      </div>
    </div>

    <!-- Dots -->
    <div class="flex justify-center gap-3 mt-10">
      <button class="dot w-3 h-3 bg-black rounded-full"></button>
      <button class="dot w-3 h-3 bg-black/30 rounded-full"></button>
      <button class="dot w-3 h-3 bg-black/30 rounded-full"></button>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('carousel');
  const slides = document.querySelectorAll('#carousel > div');
  const dots = document.querySelectorAll('.dot');

  let index = 0;
  const total = slides.length;

  function updateCarousel() {
    carousel.style.transition = 'transform 0.5s ease-in-out';
    carousel.style.transform = `translateX(-${index * 100}%)`;

    // Update dots
    dots.forEach((dot) => {
      dot.classList.remove('bg-black');
      dot.classList.add('bg-black/30');
    });
    dots[index % dots.length].classList.remove('bg-black/30');
    dots[index % dots.length].classList.add('bg-black');
  }

  // Dot click handler
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      index = i;
      updateCarousel();
    });
  });

  // Automatic looping
  setInterval(() => {
    index = (index + 1) % total;
    updateCarousel();
  }, 5000);

  updateCarousel();
</script>
