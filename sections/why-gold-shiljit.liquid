{% schema %}
{
  "name": "Why Gold Shiljit",
  "settings": [
    {
      "type": "header",
      "content": "Lab Report Banner"
    },
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Banner Heading",
      "default": "Stop guessing what's in your supplement."
    },
    {
      "type": "text",
      "id": "banner_subheading",
      "label": "Banner Subheading",
      "default": "Choose the shilajit that proves potency and screens for cleanliness."
    },
    {
      "type": "text",
      "id": "banner_button_text",
      "label": "Banner Button Text",
      "default": "View Lab Report"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Banner Link"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Why Gold Shiljit"
    }
  ]
}
{% endschema %}

<section
  class="py-16 md:py-24"
>
  <div class="max-w-[1300px] mx-auto px-6 text-center">
    <span class="inline-block border border-[#2a2620] bg-[#121212]/50 rounded-full px-6 py-2 text-[10px] md:text-sm uppercase tracking-[0.2em] text-[#e5e5e5] font-medium">
      Third-party Verified &bull; Premium-Grade &bull; Transparent
    </span>

    <!-- Main Heading -->
    <h2 class="text-4xl md:text-6xl font-black my-8 text-white tracking-tight leading-[0.9]">
      Why Pure Shilajit™ <br class="hidden md:block">
      Feels Different
    </h2>

    <!-- Subheading / Description -->
    <p class="text-[#b1b1b1] text-md md:text-lg max-w-3xl mx-auto leading-tight font-medium">
      Most brands ask you to trust the label. We back ours <br class="hidden md:block">
      with independent testing and clean screening.
    </p>

    <!-- Potency Cards -->
    <div
      class="mt-16 flex flex-col md:flex-row gap-6 text-left"
    >
      <!-- Left Card: Percentage -->
      <div
        style="background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));"
        class="batch w-full md:w-1/3 flex-grow flex flex-col justify-center p-8 md:p-12 rounded-[2rem] border border-[#2a2620] min-h-[260px] md:min-h-[380px] gap-2 md:gap-4"
      >
        <div>
          <span class="text-[60px] md:text-[74px] font-bold text-[#E6C69B] leading-none tracking-tighter">82.8%</span>
        </div>
        <div>
          <p class="text-white text-sm">
            <span class="font-bold">Fulvic Acid</span>
            <span class="text-[#8e8e8e] font-medium">Independently tested potency</span>
          </p>
        </div>
      </div>

      <!-- Right Card: Details -->
      <div class="batch w-full md:w-2/3 flex-grow-[2] p-8 md:p-12 rounded-[2rem] bg-[#0c0c0d] border border-[#1a1a1b] flex flex-col justify-between min-h-[300px] md:min-h-[380px]">
        <div>
          <h3 class="text-white text-2xl font-bold mb-6">Potency you can verify</h3>
          <p class="text-[#b1b1b1] text-base leading-relaxed font-medium max-w-2xl">
            Fulvic acid is one of the most important markers of authentic shilajit quality. Pure Shilajit™'s third-party
            report verifies a standout fulvic acid percentage — so you’re not guessing what you’re taking.
          </p>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <span class="batch px-4 py-2 rounded-full text-[#e5e5e5] text-sm md:text-base font-medium">
            UV-Vis Method
          </span>
          <span class="batch px-4 py-2 rounded-full text-[#e5e5e5] text-sm md:text-base font-medium">
            Heavy Metals Screened
          </span>
          <span class="batch px-4 py-2 rounded-full text-[#e5e5e5] text-sm md:text-base font-medium">
            Microbial Screened
          </span>
          <span class="batch px-4 py-2 rounded-full text-[#e5e5e5] text-sm md:text-base font-medium">
            Transparency First
          </span>
        </div>
      </div>
    </div>
    <!-- Feature Cards Row -->
    <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 text-left">
      <!-- Card 1 -->
      <div class="batch p-6 rounded-[1.5rem] bg-[#0c0c0d] border border-[#1a1a1b] flex flex-col gap-4">
        <div class="w-10 h-10 rounded-lg bg-[#1c1a17] border border-[#2a2620] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="#E6C69B"/>
          </svg>
        </div>
        <div>
          <h4 class="text-white font-bold mb-2">Independently Tested</h4>
          <p class="text-[#8e8e8e] text-sm leading-relaxed">
            No "in-house" numbers. Verified by a third-party lab so your decision is based on proof.
          </p>
        </div>
      </div>

      <!-- Card 2 -->
      <div class="batch p-6 rounded-[1.5rem] bg-[#0c0c0d] border border-[#1a1a1b] flex flex-col gap-4">
        <div class="w-10 h-10 rounded-lg bg-[#1c1a17] border border-[#2a2620] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="#E6C69B"/>
          </svg>
        </div>
        <div>
          <h4 class="text-white font-bold mb-2">Screened for Heavy Metals</h4>
          <p class="text-[#8e8e8e] text-sm leading-relaxed">
            Tested for arsenic, lead, mercury, and cadmium to help ensure clean sourcing.
          </p>
        </div>
      </div>

      <!-- Card 3 -->
      <div class="batch p-6 rounded-[1.5rem] bg-[#0c0c0d] border border-[#1a1a1b] flex flex-col gap-4">
        <div class="w-10 h-10 rounded-lg bg-[#1c1a17] border border-[#2a2620] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="#E6C69B"/>
          </svg>
        </div>
        <div>
          <h4 class="text-white font-bold mb-2">Microbial Screening</h4>
          <p class="text-[#8e8e8e] text-sm leading-relaxed">
            Screened for common contaminants so you can feel confident in daily use.
          </p>
        </div>
      </div>

      <!-- Card 4 -->
      <div class="batch p-6 rounded-[1.5rem] bg-[#0c0c0d] border border-[#1a1a1b] flex flex-col gap-4">
        <div class="w-10 h-10 rounded-lg bg-[#1c1a17] border border-[#2a2620] flex items-center justify-center">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="#E6C69B"/>
          </svg>
        </div>
        <div>
          <h4 class="text-white font-bold mb-2">Premium-Grade Standard</h4>
          <p class="text-[#8e8e8e] text-sm leading-relaxed">
            High fulvic acid is a quality signal — we lead with it because premium should be measurable.
          </p>
        </div>
      </div>
    </div>

    <div
      style="background: radial-gradient(circle at 10% 50%, rgba(230, 198, 155, 0.08), transparent 40%), radial-gradient(circle at 90% 50%, rgba(230, 198, 155, 0.08), transparent 40%), #0c0c0d;"
      class="batch mt-8 py-6 px-6 md:py-8 md:px-12 rounded-[2.5rem] border border-[#2a2620] flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left"
    >
      <div>
        <h3 class="text-white text-2xl md:text-3xl font-bold mb-3 tracking-tight">
          {{ section.settings.banner_heading | default: "Stop guessing what's in your supplement." }}
        </h3>
        <p class="text-[#8e8e8e] text-sm md:text-base font-medium leading-relaxed">
          {{
            section.settings.banner_subheading
            | default: 'Choose the shilajit that proves potency and screens for cleanliness.'
          }}
        </p>
      </div>
      <div>
        <a
          href="{{ section.settings.banner_link | default: '#' }}"
          class="inline-block bg-[#E6C69B] text-black px-10 py-4 rounded-full font-bold text-sm md:text-base hover:opacity-90 transition-opacity whitespace-nowrap shadow-[0_0_20px_rgba(230,198,155,0.2)]"
        >
          {{ section.settings.banner_button_text | default: 'View Lab Report' }}
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .batch {
    border: 1px solid #2a2620;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    display: block;
    will-change: transform;
  }
  .batch:hover {
    transform: translateY(-8px);
    border-color: #4a4a4a;
  }
  .batch-fff {
    border: 1px solid #fff;
  }
{% endstylesheet %}
