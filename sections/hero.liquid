{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_background",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "default": "Raw. Ancient. Powerful."
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle",
      "default": "Perform at your peak & feel like yourself again"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop now"
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "default": 4.9
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Number of reviews",
      "default": "5,000+"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "30-Day Money-Back Guarantee"
    },
    {
      "type": "product",
      "id": "product_one",
      "label": "Product One"
    },
    {
      "type": "product",
      "id": "product_two",
      "label": "Product Two"
    }
  ],
  "presets": [
    {
      "name": "Hero Section"
    }
  ]
}
{% endschema %}

<section
  class="relative overflow-hidden bg-cover bg-center"
  style="background-image: url('{{ section.settings.hero_background | image_url: width: 2048 }}');"
>
  <!-- Gradient Overlay -->
  <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/60 to-transparent"></div>

  <!-- Content -->
  <div class="relative max-w-[1300px] mx-auto px-6 py-24 flex flex-wrap items-center justify-between text-[#f3e2c2] z-10">
    <!-- LEFT CONTENT -->
    <div class="max-w-[600px]">
      <p class="uppercase tracking-widest text-sm text-[#e8d6a8] mb-4">
        {{ section.settings.small_label }}
      </p>

      <h1 class="text-5xl lg:text-6xl text-[#e6d2a3] font-extrabold leading-tight mb-6">
        {{ section.settings.hero_title }}
      </h1>

      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md border border-white/20 rounded-full px-4 py-2 mb-6">
        {% assign rounded_rating = section.settings.star_rating | round %}
        <div class="flex">
          {% for i in (1..5) %}
            {% if i <= rounded_rating %}
              <svg class="w-4 h-4 fill-green-400" viewBox="0 0 24 24">
                <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.917 1.432 8.271L12 18.897l-7.368 4.697 1.432-8.271-6.064-5.917 8.332-1.151z"/>
              </svg>
            {% else %}
              <svg class="w-4 h-4 fill-gray-400" viewBox="0 0 24 24">
                <path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.917 1.432 8.271L12 18.897l-7.368 4.697 1.432-8.271-6.064-5.917 8.332-1.151z"/>
              </svg>
            {% endif %}
          {% endfor %}
        </div>

        <span class="text-sm text-white">
          Rated {{ section.settings.star_rating }}/5 by {{ section.settings.review_count }}+ reviews
        </span>
      </div>

      <p class="text-lg text-[#e9e2d3] mb-8 max-w-[500px]">
        {{ section.settings.hero_subtitle }}
      </p>

      <div class="flex flex-wrap gap-3 mb-8">
        <span class="bg-white/10 backdrop-blur-md border border-white/20 px-5 py-2 rounded-full text-sm font-semibold">
          ⚡ Energy & Vitality
        </span>

        <span class="bg-white/10 backdrop-blur-md border border-white/20 px-5 py-2 rounded-full text-sm font-semibold">
          ⛰ Ancient Mineral Power
        </span>

        <span class="bg-white/10 backdrop-blur-md border border-white/20 px-5 py-2 rounded-full text-sm font-semibold">
          ✔ Pure · Lab-Tested · Clean Formula
        </span>
      </div>

      <a
        href="{{ section.settings.cta_url }}"
        class="inline-block bg-[#e7d2a5] text-black font-bold px-10 py-4 rounded-full text-lg transition duration-300 hover:scale-105 hover:bg-[#f3e2c2] shadow-xl"
      >
        {{ section.settings.cta_text }}
      </a>

      <div class="mt-5 text-sm text-white flex items-center gap-2">
        <span class="text-green-400">✔</span>
        {{ section.settings.guarantee_text }}
      </div>
    </div>

    <!-- RIGHT PRODUCT IMAGES -->
    <div class="flex gap-6 mt-16 lg:mt-0 items-end">
      {% if section.settings.product_one %}
        <a href="{{ section.settings.product_one.url }}">
          <img
            class="w-[170px] lg:w-[220px] drop-shadow-2xl"
            src="{{ section.settings.product_one.featured_image | image_url: width: 500 }}"
            alt="{{ section.settings.product_one.title }}"
          >
        </a>
      {% endif %}

      {% if section.settings.product_two %}
        <a href="{{ section.settings.product_two.url }}">
          <img
            class="w-[150px] lg:w-[200px] drop-shadow-2xl translate-y-6"
            src="{{ section.settings.product_two.featured_image | image_url: width: 500 }}"
            alt="{{ section.settings.product_two.title }}"
          >
        </a>
      {% endif %}
    </div>
  </div>
</section>
