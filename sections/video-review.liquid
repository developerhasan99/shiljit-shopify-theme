{% schema %}
{
  "name": "Video Review",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real People. Restored Power."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>The Shift Is Real: See How <strong>Gold Shilajit</strong> Are Transforming Lives</p>"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 6,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted Video"
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "Poster Image (Optional fallback)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Review",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}

<section class="py-10 overflow-hidden" style="background-color: {{ section.settings.background_color }};">
  <div class="max-w-[1400px] mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-10 md:mb-16">
      {% if section.settings.heading != blank %}
        <h2 class="text-3xl md:text-5xl font-black text-black leading-tight mb-4 tracking-tight">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="text-[#666] text-base md:text-lg">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>

    <!-- Video Grid / Carousel -->
    <!-- On desktop: CSS grid (flex wrap or columns). On mobile: horizontal scroll -->
    <div class="flex overflow-x-auto md:grid md:grid-cols-5 gap-4 md:gap-6 pb-6 md:pb-0 snap-x snap-mandatory scrollbar-hide">
      {% for block in section.blocks %}
        <div
          class="video-review-card relative flex-shrink-0 w-[240px] md:w-auto h-[420px] md:h-[500px] snap-center rounded-[1rem] overflow-hidden bg-black shadow-lg"
          {{ block.shopify_attributes }}
        >
          {% if block.settings.video != blank %}
            {{
              block.settings.video
              | video_tag:
                image_size: '600x',
                autoplay: false,
                loop: true,
                controls: true,
                muted: false,
                class: 'w-full h-full object-cover absolute inset-0'
            }}
          {% else %}
            <!-- Fallback Mockup Video State -->
            <div class="w-full h-full bg-[#f3f3f3] flex flex-col justify-end p-4 relative">
              <div class="absolute inset-0 flex items-center justify-center text-[#999]">No Video</div>
              <div class="relative z-10 flex items-center justify-between text-white bg-black/50 p-2 rounded">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                <span class="text-xs">0:00</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                  <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                </svg>
              </div>
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  /* Hide scrollbar for Chrome, Safari and Opera */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  /* Hide scrollbar for IE, Edge and Firefox */
  .scrollbar-hide {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  .video-review-card video {
    /* Ensures native controls aren't cut off by object-cover */
    object-fit: cover !important;
  }
{% endstyle %}
