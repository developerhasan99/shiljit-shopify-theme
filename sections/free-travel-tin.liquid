{% schema %}
{
  "name": "Free Travel Tin",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FREE! Travel Tin with orders over $80"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Take your routine anywhere."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>This compact travel tin keeps your gummies protected, discreet, and ready whenever you need them — at home or on the go.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Xara Shilajit"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "(Rated 4.95/5 by 15,600+)"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Free Travel Tin"
    }
  ]
}
{% endschema %}

<section
  class="free-travel-tin-section"
  style="background-color: {{ section.settings.background_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="max-w-[1300px] mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20">
      <!-- Text Content -->
      <div class="w-full md:w-3/5 text-center flex flex-col items-center order-2 md:order-1">
        <h2 class="text-3xl md:text-[44px] font-black text-black mb-6 md:mb-8 leading-[1.1] max-w-lg">
          {{ section.settings.heading }}
        </h2>

        <p class="text-[14px] md:text-[16px] font-bold text-black mb-4 md:mb-6 tracking-wide">
          {{ section.settings.subheading }}
        </p>

        <div class="text-[14px] md:text-[16px] text-gray-700 mb-8 md:mb-10 max-w-xl leading-relaxed">
          {{ section.settings.description }}
        </div>

        <a
          href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
          class="inline-block bg-[#111] text-white text-[13px] md:text-[14px] font-bold px-10 py-4 md:py-5 rounded-lg uppercase tracking-[0.05em] hover:bg-black transition-all mb-6 md:mb-8 shadow-sm"
        >
          {{ section.settings.button_label }}
        </a>

        <div class="flex items-center gap-2">
          <div class="flex gap-0.5 text-[#ffcc00]">
            {% for i in (1..5) %}
              <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
            {% endfor %}
          </div>
          <span class="text-[13px] font-medium text-black/80">{{ section.settings.rating_text }}</span>
        </div>
      </div>

      <!-- Image Content -->
      <div class="w-full md:w-2/5 order-1 md:order-2">
        <div class="relative aspect-[4/5] md:aspect-[3/4] overflow-hidden rounded-[24px] md:rounded-[32px] shadow-sm">
          {% if section.settings.image %}
            {{
              section.settings.image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', class: 'w-full h-full object-cover', widths: '400, 800, 1200'
            }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .free-travel-tin-section h2 {
    font-family: inherit; /* Adjust if a specific font is used for headings */
  }
  .free-travel-tin-section p {
    margin-bottom: 0;
  }
  .free-travel-tin-section .text-gray-700 p {
    margin-bottom: 1rem;
  }
  .free-travel-tin-section .text-gray-700 p:last-child {
    margin-bottom: 0;
  }
</style>
