{% schema %}
{
  "name": "Animated Feature Bar",
  "settings": [],
  "blocks": [],
  "presets": [
    {
      "name": "Animated Feature Bar"
    }
  ]
}
{% endschema %}

<div class="feature-bar py-3 bg-black border-b border-white/5">
  <ul class="feature-bar__list flex items-center gap-12 whitespace-nowrap animate-marquee">
    {%- for i in (1..5) -%}
      <li class="feature-bar__item flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white">
          <path d="M12 2L2 22h20L12 2z"/>
        </svg>
        <p class="feature-bar__text text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-white">
          Focus & Mental Clarity
        </p>
      </li>
      <li class="feature-bar__item flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white">
          <path d="M12 2L2 22h20L12 2z"/>
        </svg>
        <p class="feature-bar__text text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-white">
          Strength & Stamina
        </p>
      </li>
      <li class="feature-bar__item flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white">
          <path d="M12 2L2 22h20L12 2z"/>
        </svg>
        <p class="feature-bar__text text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-white">
          Libido & Performance
        </p>
      </li>
      <li class="feature-bar__item flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="white">
          <path d="M12 2L2 22h20L12 2z"/>
        </svg>
        <p class="feature-bar__text text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-white">
          Natural Energy Support
        </p>
      </li>
    {%- endfor -%}
  </ul>
</div>

<style>
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

{% stylesheet %}
  .feature-bar {
    overflow: hidden;
    position: relative;
    width: 100%;
    background-color: #121212;
    padding: 2rem 0;
  }

  .feature-bar__list {
    display: flex;
    gap: 4rem;
    animation: feature-scroll 20s linear infinite;
  }

  .feature-bar__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .feature-bar__text {
    color: #fff;
    font-size: 16px;
    margin: 0;
  }
  .feature-bar__icon {
    margin: 0;
    display: flex;
  }
  .feature-bar__icon svg {
    color: #fff;
    margin: 0;
    fill: white;
  }

  @keyframes feature-scroll {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(0);
    }
  }
{% endstylesheet %}
