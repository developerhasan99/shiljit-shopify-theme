{% schema %}
{
  "name": "Certificate",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "certificate_image",
      "label": "Certificate Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "82% Fulvic Acid. No heavy Metals. Pure Shilajit™."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Xara is the only brad where we confidentaly showcase our 3rd Party lab test showing over 82% fulvic acid, most fake shilajit has less than 20%"
    }
  ],
  "presets": [
    {
      "name": "Certificate"
    }
  ]
}
{% endschema %}

<section class="py-12" style="background-color: {{ section.settings.background_color }};">
  <div class="max-w-[1300px] mx-auto px-6">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
      <!-- Image Column (Lab Test) -->
      <div class="w-full lg:w-1/2">
        <div class="relative w-full rounded-lg overflow-hidden shadow-sm border border-gray-100">
          {% if section.settings.certificate_image %}
            {{
              section.settings.certificate_image
              | image_url: width: 1200
              | image_tag: loading: 'lazy', class: 'w-full h-auto block', widths: '600, 800, 1000, 1200'
            }}
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-auto bg-gray-50' }}
          {% endif %}
        </div>
      </div>

      <!-- Content Column -->
      <div class="w-full lg:w-1/2 flex flex-col text-left">
        <h2 class="text-3xl md:text-4xl font-extrabold text-[#111111] mb-8 tracking-tight leading-10">
          {{ section.settings.heading }}
        </h2>
        <div class="text-[#000] text-base leading-relaxed font-normal max-w-xl">
          {{ section.settings.description | newline_to_br }}
        </div>
      </div>
    </div>
  </div>
</section>
